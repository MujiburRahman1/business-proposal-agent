# Google AI Studio (local dev)
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your_gemini_api_key_here

# Or Vertex AI (production / hackathon deploy)
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

GEMINI_MODEL=gemini-2.5-flash

# MongoDB MCP (official server uses this variable name)
MDB_MCP_CONNECTION_STRING=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/proposaldb?appName=Cluster0
MONGODB_DATABASE=proposaldb
