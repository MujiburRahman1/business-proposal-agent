# DealPilot ADK agent (default — used by frontend)
ADK_AGENT_URL=http://127.0.0.1:8080
ADK_APP_NAME=dealpilot
USE_ADK_AGENT=true

# Fallback FastAPI backend (set USE_ADK_AGENT=false to use this instead)
BACKEND_URL=http://127.0.0.1:8000

# Anvil — PDF generation (free dev key with watermark)
ANVIL_API_KEY=your_anvil_api_key_here
